{
  "name": "@enterwell/enum-helper",
  "version": "2.1.0",
  "description": "JavaScript enum helper.",
  "license": "MIT",
  "repository": "https://github.com/Enterwell/js-enum-helper",
  "author": {
    "name": "Enterwell",
    "email": "services@enterwell.net",
    "url": "http://enterwell.net"
  },
  "engines": {
    "node": ">=5"
  },
  "public": true,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check-types": "tsc",
    "test": "npm run build && npm run check-types && jest",
    "test:watch": "npm test -- --watch",
    "build": "tsup"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    ""
  ],
  "devDependencies": {
    "@babel/cli": "^7.17.6",
    "@babel/core": "^7.17.9",
    "@babel/preset-env": "^7.16.11",
    "@babel/preset-typescript": "^7.16.7",
    "babel-jest": "^27.5.1",
    "jest": "^27.5.1",
    "tsup": "^8.5.1",
    "typescript": "^4.6.3"
  }
}
